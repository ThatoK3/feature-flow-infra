# FeatureFlow — environment variables
# Copy to .env and fill in values before docker compose up

# MongoDB
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme_mongo

# PostgreSQL
POSTGRES_USER=featureflow
POSTGRES_PASSWORD=changeme_pg
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=changeme_repl

# MS SQL Server (min 8 chars, upper+lower+digit+symbol)
MSSQL_SA_PASSWORD=FeatureFlow_SA1!

# MySQL
MYSQL_ROOT_PASSWORD=changeme_mysql_root
MYSQL_USER=featureflow
MYSQL_PASSWORD=changeme_mysql

# MinIO
MINIO_ROOT_USER=featureflow
MINIO_ROOT_PASSWORD=changeme_minio

# Redis
REDIS_PASSWORD=changeme_redis
