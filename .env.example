# FeatureFlow — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your passwords before running make setup.
# .env is gitignored — never commit real credentials.
#
# Password requirements:
#   SA_PASSWORD        Must meet SQL Server complexity rules:
#                      ≥8 chars, upper + lower + digit + symbol
#   CDC_PASSWORD       Used for the read-only CDC user across all databases
#   All others         Minimum 8 characters recommended

# ── SQL Server ────────────────────────────────────────────────────────────────
SA_PASSWORD=ChangeMe@2024!

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=ChangeMe@2024!
MYSQL_PASSWORD=ChangeMe_app2024!

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_PASSWORD=ChangeMe@2024!

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=ChangeMe@2024!

# ── Shared CDC user (created in MySQL, MongoDB, PostgreSQL) ───────────────────
# This user gets read-only / replication privileges across all three databases.
CDC_PASSWORD=CdcChangeMe@2024!

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_USER=featureflow
MINIO_PASSWORD=ChangeMe@2024!
